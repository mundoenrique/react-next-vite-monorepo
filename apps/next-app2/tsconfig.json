{
  "extends": "@repo/typescript-config/tsconfig.next",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.next.tsbuildinfo",
    "paths": {
      "@/*": ["./src/*"]
