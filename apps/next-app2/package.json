{
  "name": "next-app2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint --css-linter-enabled=false --config-path ../../biome.json src next.config.ts",
    "format": "biome format --write --config-path ../../biome.json src package.json next.config.ts postcss.config.mjs tsconfig.json",
    "format:check": "biome format --config-path ../../biome.json src package.json next.config.ts postcss.config.mjs tsconfig.json",
    "check-types": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@repo/shadcn-ui": "^1.0.0",
    "@repo/ui": "^1.0.0",
    "next": "16.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@repo/eslint-config": "^1.0.0",
    "@repo/typescript-config": "^1.0.0",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4"
  }
}
