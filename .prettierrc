{
  "bracketSameLine": false,
  "endOfLine": "lf",
  "jsxSingleQuote": false,
  "printWidth": 120,
  "semi": true,
  "singleAttributePerLine": false,
  "singleQuote": true,
  "tabWidth": 2,
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindFunctions": ["cn", "cva"],
  "tailwindStylesheet": "packages/shadcn-ui/src/styles/globals.css",
  "trailingComma": "es5"
}
