{
  "name": "react-next-vite-monorepo",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "quality:configs:smoke": "turbo run lint check-types --filter=@repo/ui --filter=next-app --filter=next-app2 --filter=vite-app --filter=vite-app2",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "globals": "^17",
    "husky": "^9",
    "lint-staged": "^16",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx}": [
      "eslint"
    ],
    "*.{js,jsx,mjs,cjs,ts,tsx,json,md,mdx,css,scss,html,yml,yaml}": [
      "prettier --check"
    ]
  }
}
