echo ""
echo ">>> HUSKY PRE-PUSH RUNNING (lint + typecheck) <<<"
echo "Running workspace quality gates before push."
echo ""

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

if ! npm run lint; then
	echo ""
	echo ">>> HUSKY PRE-PUSH FAILED (lint) <<<"
	echo "Run 'npm run lint' locally and fix reported issues before pushing."
	echo ""
	exit 1
fi

if ! npm run check-types; then
	echo ""
	echo ">>> HUSKY PRE-PUSH FAILED (check-types) <<<"
	echo "Run 'npm run check-types' locally and fix type errors before pushing."
	echo ""
	exit 1
fi

echo ">>> HUSKY PRE-PUSH: validations completed. <<<"
