{
  "name": "@repo/shadcn-ui",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "lint": "cd ../.. && biome lint --css-linter-enabled=false --config-path ./biome.json packages/shadcn-ui",
    "format": "cd ../.. && biome format --write --config-path ./biome.json --vcs-root . packages/shadcn-ui",
    "format:check": "cd ../.. && biome format --config-path ./biome.json --vcs-root . packages/shadcn-ui",
    "check-types": "tsc --noEmit"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "sideEffects": ["**/*.css"],
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "^1.0.0",
    "@repo/typescript-config": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4"
  }
}
