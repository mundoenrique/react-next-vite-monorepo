{
  "name": "@repo/ui",
  "version": "1.0.0",
  "private": true,
  "exports": {
    "./*": "./src/*.tsx"
  },
  "type": "module",
  "scripts": {
    "lint": "biome lint --css-linter-enabled=false --config-path ../../biome.json .",
    "format": "biome format --write --config-path ../../biome.json --vcs-root ../.. .",
    "format:check": "biome format --config-path ../../biome.json --vcs-root ../.. .",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "^1.0.0",
    "@repo/typescript-config": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  }
}
